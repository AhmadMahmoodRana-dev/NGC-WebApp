# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANT: Change these in production! Use strong random values.
JWT_SECRET=@@@
JWT_REFRESH_SECRET==@@@
JWT_EXPIRES=8h

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postg=@@@
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ngc_db
DB_USER=ngc_user
DB_PASSWORD=Ahmad@1122

# ── Database (MongoDB — alternative) ─────────────────────────
MONGO_URI==@@@.net/?appName=ngc

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── Email (for contact form notifications) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@ngc.gov.pk
SMTP_PASS=smtp_app_password_here
EMAIL_FROM=NGC Website <notifications@ngc.gov.pk>
EMAIL_ADMIN=info@ngc.gov.pk

# ── Google Analytics ──────────────────────────────────────────
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── MFA / TOTP ────────────────────────────────────────────────
MFA_ISSUER=NGC Staff Portal

# ── Security ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
